<Window x:Class="Hecateon.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Hecateon"
        Height="820"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#0E0A17"
        Foreground="#F4E8D1"
        FontFamily="Segoe UI"
        FontSize="14"
        MinHeight="700"
        MinWidth="1100">

    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#0E0A17"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#181226"/>
        <SolidColorBrush x:Key="PanelAltBrush" Color="#22182F"/>
        <SolidColorBrush x:Key="PanelRaisedBrush" Color="#2A1E39"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#6A4D31"/>
        <SolidColorBrush x:Key="BorderSoftBrush" Color="#4D3A28"/>
        <SolidColorBrush x:Key="GoldBrush" Color="#E7C58A"/>
        <SolidColorBrush x:Key="GoldSoftBrush" Color="#BE9B6A"/>
        <SolidColorBrush x:Key="TextMainBrush" Color="#F3E4CB"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#C5B39A"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#35C86A"/>
        <SolidColorBrush x:Key="InputBrush" Color="#130E1D"/>
        <SolidColorBrush x:Key="UserBubbleBrush" Color="#2C2239"/>
        <SolidColorBrush x:Key="AssistantBubbleBrush" Color="#1B1427"/>

        <LinearGradientBrush x:Key="WindowGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#120B1D" Offset="0"/>
            <GradientStop Color="#2A1D35" Offset="0.45"/>
            <GradientStop Color="#171124" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#2B1F38"/>
            <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A2A4B"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E1728"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LeftNavTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="NavBorder" Margin="8,4" Padding="14,10" CornerRadius="10" BorderBrush="Transparent" BorderThickness="1" Background="Transparent">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#2B1F38"/>
                                <Setter TargetName="NavBorder" Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#21182E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowGradient}">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#111111" BorderBrush="#3E2F1E" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True" VerticalAlignment="Center">
                <TextBlock Text="Hecateon" Foreground="{StaticResource TextMainBrush}" FontSize="22" FontWeight="SemiBold" Margin="14,0,0,0" VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center">
                    <TextBlock Text="●" Foreground="#8A7A63" FontSize="12" Margin="0,0,10,0"/>
                    <TextBlock Text="●" Foreground="#8A7A63" FontSize="12" Margin="0,0,10,0"/>
                    <TextBlock Text="□" Foreground="#8A7A63" FontSize="12"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Margin="10" Padding="10" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Background="#120D1D">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="0,0,10,0" Background="#171125" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1" CornerRadius="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Margin="10" Padding="12" Background="#20172F" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10">
                            <StackPanel>
                                <TextBlock Text="Hecateon" FontSize="44" FontWeight="Bold" Foreground="{StaticResource GoldBrush}"/>
                                <TextBlock Text="Local Stability Operating System" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Margin="10,0,10,0" Background="Transparent">
                            <TabControl x:Name="MainTabs" TabStripPlacement="Left" Background="Transparent" BorderThickness="0">
                                <TabControl.Resources>
                                    <Style TargetType="TabPanel">
                                        <Setter Property="IsItemsHost" Value="True"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                </TabControl.Resources>

                                <TabItem Style="{StaticResource LeftNavTabItemStyle}">
                                    <TabItem.Header>
                                        <TextBlock Text="✦  Chat" FontSize="30" FontWeight="SemiBold"/>
                                    </TabItem.Header>
                                    <Grid Background="Transparent">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="280"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Column="0" Margin="14,10,10,10">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                                <TextBlock Text="CHAT • STATE READINESS • 4h WINDOW" Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                                                <DockPanel Margin="0,4,0,0">
                                                    <TextBlock Text="HECATEON" Foreground="{StaticResource GoldBrush}" FontSize="28" FontWeight="SemiBold"/>
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Ellipse x:Name="ConnectionDot" Width="10" Height="10" Fill="{StaticResource SuccessBrush}" Margin="0,0,8,0"/>
                                                        <TextBlock x:Name="ConnectionStatus" Text="Connected" Foreground="{StaticResource TextMainBrush}" FontSize="14"/>
                                                    </StackPanel>
                                                </DockPanel>
                                            </StackPanel>

                                            <Grid Grid.Row="1">
                                                <ListBox x:Name="MessagesList" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" Padding="6" ItemsSource="{Binding ChatMessages}">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,8,0,8">
                                                                <StackPanel HorizontalAlignment="Right" Visibility="{Binding IsUserVisibility}" Margin="140,0,0,0" MaxWidth="560">
                                                                    <Border Background="{StaticResource UserBubbleBrush}" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1" CornerRadius="18" Padding="14,10">
                                                                        <TextBlock Text="{Binding Text}" Foreground="{StaticResource GoldBrush}" TextWrapping="Wrap" FontSize="17" LineHeight="22"/>
                                                                    </Border>
                                                                    <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm'}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,6,4,0" TextAlignment="Right"/>
                                                                </StackPanel>
                                                                <StackPanel HorizontalAlignment="Left" Visibility="{Binding IsAssistantVisibility}" Margin="0,0,140,0" MaxWidth="560">
                                                                    <Border Background="{StaticResource AssistantBubbleBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="18" Padding="14,10">
                                                                        <TextBlock Text="{Binding Text}" Foreground="{StaticResource TextMainBrush}" TextWrapping="Wrap" FontSize="17" LineHeight="22"/>
                                                                    </Border>
                                                                    <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm'}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="4,6,0,0"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>

                                                <Border x:Name="ErrorBanner" Visibility="Collapsed" VerticalAlignment="Top" Margin="6" Background="#5B1F24" BorderBrush="#C55D62" BorderThickness="1" CornerRadius="8" Padding="12">
                                                    <StackPanel>
                                                        <TextBlock Text="Error" FontWeight="Bold" Foreground="#FFD8D8"/>
                                                        <TextBlock x:Name="ErrorMessage" Foreground="#FFD8D8" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <Grid Grid.Row="2" Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="120"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="ChatInput" Grid.Column="0" Style="{StaticResource InputTextBoxStyle}" MinHeight="56" MaxHeight="120" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,10,0"/>
                                                <Button Grid.Column="1" Content="Send" Style="{StaticResource PrimaryButtonStyle}" Click="SendMessage_Click" MinHeight="56"/>
                                            </Grid>
                                        </Grid>

                                        <Border Grid.Column="1" Margin="0,10,10,10" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="LIVE STATE METRICS" Foreground="{StaticResource GoldBrush}" FontSize="18" FontWeight="SemiBold"/>
                                                <Border Background="#1A3A2A" BorderBrush="#4D8E63" BorderThickness="1" CornerRadius="14" Padding="10,4" HorizontalAlignment="Left" Margin="0,10,0,14">
                                                    <TextBlock Text="STABLE" Foreground="#B8F1C8" FontSize="12" FontWeight="SemiBold"/>
                                                </Border>

                                                <StackPanel>
                                                    <DockPanel><TextBlock Text="Operator" Foreground="{StaticResource TextMainBrush}"/><TextBlock Text="53%" Foreground="{StaticResource GoldBrush}" DockPanel.Dock="Right"/></DockPanel>
                                                    <ProgressBar Value="53" Height="8" Margin="0,4,0,12" Background="#312338" Foreground="#D7A95D"/>
                                                    <DockPanel><TextBlock Text="Child" Foreground="{StaticResource TextMainBrush}"/><TextBlock Text="47%" Foreground="{StaticResource GoldBrush}" DockPanel.Dock="Right"/></DockPanel>
                                                    <ProgressBar Value="47" Height="8" Margin="0,4,0,12" Background="#312338" Foreground="#D7A95D"/>
                                                    <DockPanel><TextBlock Text="Beast" Foreground="{StaticResource TextMainBrush}"/><TextBlock Text="16%" Foreground="{StaticResource GoldBrush}" DockPanel.Dock="Right"/></DockPanel>
                                                    <ProgressBar Value="16" Height="8" Margin="0,4,0,12" Background="#312338" Foreground="#D7A95D"/>
                                                    <DockPanel><TextBlock Text="Overload" Foreground="{StaticResource TextMainBrush}"/><TextBlock Text="6%" Foreground="{StaticResource GoldBrush}" DockPanel.Dock="Right"/></DockPanel>
                                                    <ProgressBar Value="6" Height="8" Margin="0,4,0,12" Background="#312338" Foreground="#D7A95D"/>
                                                </StackPanel>

                                                <Separator Margin="0,6,0,10" Background="{StaticResource BorderSoftBrush}"/>
                                                <DockPanel>
                                                    <TextBlock Text="Sleep Integrity" Foreground="{StaticResource TextMainBrush}"/>
                                                    <TextBlock Text="82%" Foreground="{StaticResource GoldBrush}" DockPanel.Dock="Right"/>
                                                </DockPanel>
                                                <ProgressBar Value="82" Height="8" Margin="0,6,0,14" Background="#312338" Foreground="#D7A95D"/>
                                                <DockPanel>
                                                    <TextBlock Text="Confidence: 41%" Foreground="{StaticResource TextMutedBrush}"/>
                                                    <Button Content="View Log" Style="{StaticResource PrimaryButtonStyle}" FontSize="11" Padding="10,4" DockPanel.Dock="Right"/>
                                                </DockPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </TabItem>

                                <TabItem Style="{StaticResource LeftNavTabItemStyle}">
                                    <TabItem.Header>
                                        <TextBlock Text="◈  Health" FontSize="30"/>
                                    </TabItem.Header>
                                    <ScrollViewer Background="Transparent" Padding="16,14">
                                        <StackPanel>
                                            <TextBlock Text="Health Check-In" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource GoldBrush}"/>
                                            <TextBlock Text="Track emotional and sleep state for deterministic trend analysis." Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,18"/>

                                            <Border Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,14">
                                                <StackPanel>
                                                    <TextBlock Text="How are you feeling?" FontSize="20" Foreground="{StaticResource TextMainBrush}" Margin="0,0,0,10"/>
                                                    <StackPanel x:Name="MoodButtonPanel" Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Button Content="😊&#10;Great" Tag="5" Click="MoodButton_Click" Style="{StaticResource PrimaryButtonStyle}" Width="120" Height="90" Margin="0,0,8,0" FontSize="15"/>
                                                        <Button Content="🙂&#10;Good" Tag="4" Click="MoodButton_Click" Style="{StaticResource PrimaryButtonStyle}" Width="120" Height="90" Margin="0,0,8,0" FontSize="15"/>
                                                        <Button Content="😐&#10;Okay" Tag="3" Click="MoodButton_Click" Style="{StaticResource PrimaryButtonStyle}" Width="120" Height="90" Margin="0,0,8,0" FontSize="15"/>
                                                        <Button Content="☹️&#10;Bad" Tag="2" Click="MoodButton_Click" Style="{StaticResource PrimaryButtonStyle}" Width="120" Height="90" Margin="0,0,8,0" FontSize="15"/>
                                                        <Button Content="😞&#10;Awful" Tag="1" Click="MoodButton_Click" Style="{StaticResource PrimaryButtonStyle}" Width="120" Height="90" FontSize="15"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="MoodLabel" Text="Select your mood to continue" Foreground="{StaticResource TextMutedBrush}" TextAlignment="Center" Margin="0,10,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,14">
                                                <StackPanel>
                                                    <TextBlock Text="Sleep duration" FontSize="20" Foreground="{StaticResource TextMainBrush}" Margin="0,0,0,8"/>
                                                    <Slider x:Name="SleepSlider" Minimum="0" Maximum="12" Value="8" SmallChange="0.25" LargeChange="1"/>
                                                    <TextBlock x:Name="SleepLabel" Text="8.0 hours" Foreground="{StaticResource GoldBrush}" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <Button Content="Save Entry" Click="LogHealth_Click" Style="{StaticResource PrimaryButtonStyle}" Width="220" Height="52" FontSize="18"/>
                                            <Border Background="#173325" BorderBrush="#3E7A5B" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,12,0,0">
                                                <TextBlock x:Name="HealthStatus" Text="No entries yet" Foreground="#AFF0C4" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>

                                <TabItem Style="{StaticResource LeftNavTabItemStyle}">
                                    <TabItem.Header>
                                        <TextBlock Text="⚙  Settings" FontSize="30"/>
                                    </TabItem.Header>
                                    <ScrollViewer Background="Transparent" Padding="16,14">
                                        <StackPanel>
                                            <TextBlock Text="Settings" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource GoldBrush}"/>
                                            <TextBlock Text="Local identity, recovery controls, and privacy posture." Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,18"/>

                                            <Border Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                                                <StackPanel>
                                                    <TextBlock Text="Device ID" Foreground="{StaticResource TextMainBrush}" FontWeight="SemiBold"/>
                                                    <Grid Margin="0,8,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox x:Name="DeviceIdBox" Grid.Column="0" Style="{StaticResource InputTextBoxStyle}" IsReadOnly="True" FontFamily="Consolas" FontSize="13"/>
                                                        <Button Grid.Column="1" Content="Copy" Click="CopyDeviceId_Click" Style="{StaticResource PrimaryButtonStyle}" Margin="10,0,0,0"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <Border Background="#463A16" BorderBrush="#8C7340" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                                                <StackPanel>
                                                    <TextBlock Text="Recovery Code" Foreground="#F6E7B5" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Store this code offline. It can bypass device approval." Foreground="#E2CF95" Margin="0,6,0,10"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox x:Name="RecoveryCodeBox" Grid.Column="0" Style="{StaticResource InputTextBoxStyle}" IsReadOnly="True" FontFamily="Consolas" FontSize="13"/>
                                                        <Button x:Name="ShowRecoveryBtn" Grid.Column="1" Content="Show" Click="ToggleRecoveryCode_Click" Style="{StaticResource PrimaryButtonStyle}" Margin="10,0,0,0"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <Border Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                                                <StackPanel>
                                                    <TextBlock Text="Security Baseline" Foreground="{StaticResource TextMainBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                    <TextBlock Text="• AES-256-GCM encrypted local state" Foreground="{StaticResource TextMutedBrush}"/>
                                                    <TextBlock Text="• Append-only event log" Foreground="{StaticResource TextMutedBrush}"/>
                                                    <TextBlock Text="• Offline-first control model" Foreground="{StaticResource TextMutedBrush}"/>
                                                    <TextBlock Text="• Device remains source of truth" Foreground="{StaticResource TextMutedBrush}"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>
                            </TabControl>
                        </Border>

                        <Border Grid.Row="2" Margin="10" Padding="10" CornerRadius="10" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1" Background="#120E1D">
                            <StackPanel>
                                <TextBlock Text="● STABLE" Foreground="{StaticResource SuccessBrush}" FontSize="26" FontWeight="SemiBold"/>
                                <TextBlock Text="Build #2214" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
