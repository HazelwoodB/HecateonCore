@page "/settings"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject HttpClient Http
@inject NavigationManager Navigation
@using System.Text.Json

<PageTitle>Settings - Hecateon</PageTitle>

<div class="settings-container">
    <div class="settings-header">
        <h2>⚙️ Settings</h2>
        <p class="subtitle">Manage your account, device trust, and privacy settings</p>
    </div>

    <div class="settings-content">
        <!-- Device Info Section -->
        <div class="settings-card">
            <h3>📱 Device Information</h3>
            <div class="info-group">
                <label>Device ID</label>
                <div class="device-id-display">
                    <code>@deviceId</code>
                    <button class="copy-btn" @onclick="CopyDeviceId" title="Copy device ID">📋</button>
                </div>
                <p class="help-text">This ID uniquely identifies your device. Use it to approve access from other devices. Never share this with untrusted sources.</p>
            </div>
            <div class="info-group">
                <label>Connection Status</label>
                <div class="status-badge @(isConnected ? "connected" : "disconnected")">
                    @if (isConnected) { 
                        <span>✓ Connected to server</span> 
                    } else { 
                        <span>✗ Offline mode</span> 
                    }
                </div>
            </div>
        </div>

        <!-- Device Enrollment Section -->
        <div class="settings-card">
            <h3>🔐 Trusted Devices</h3>
            <p class="help-text">Manage which devices can access your data. Only approved devices can sync.</p>
            
            @if (showEnrollmentForm)
            {
                <div class="form-section enrollment-form">
                    <p class="info-text"><strong>Enroll a New Device</strong></p>
                    <p class="help-text small">To enroll a new device, you must provide the recovery code. This protects your data from unauthorized access.</p>
                    
                    <div class="form-group">
                        <label>Recovery Code</label>
                        <input type="password" @bind="enrollRecoveryCode" class="form-input" placeholder="Your recovery code" />
                    </div>
                    
                    <div class="form-group">
                        <label>Device ID to Enroll</label>
                        <input type="text" @bind="enrollDeviceId" class="form-input" placeholder="e.g., phone-001" />
                    </div>
                    
                    <div class="form-group">
                        <label>Display Name (optional)</label>
                        <input type="text" @bind="enrollDisplayName" class="form-input" placeholder="e.g., My iPhone" />
                    </div>
                    
                    @if (!string.IsNullOrEmpty(enrollmentError))
                    {
                        <div class="error-message">@enrollmentError</div>
                    }
                    
                    <div class="button-group">
                        <button class="btn-primary" @onclick="EnrollDevice" disabled="@isEnrolling">
                            @if (isEnrolling) { <span>Enrolling...</span> } else { <span>Enroll & Approve</span> }
                        </button>
                        <button class="btn-secondary" @onclick="() => { showEnrollmentForm = false; enrollmentError = string.Empty; }">Cancel</button>
                    </div>
                </div>
            }
            else
            {
                <button class="btn-secondary" @onclick="() => showEnrollmentForm = true">+ Add Trusted Device</button>
            }

            @if (enrolledDevices.Count > 0)
            {
                <div class="devices-list">
                    <h4>Your Devices (@enrolledDevices.Count)</h4>
                    @foreach (var device in enrolledDevices.OrderByDescending(d => d.EnrolledUtc))
                    {
                        <div class="device-item @(device.IsApproved ? "approved" : "pending")">
                            <div class="device-header">
                                <div class="device-info">
                                    <span class="device-name">@(device.DisplayName ?? device.DeviceId)</span>
                                    <span class="device-status">
                                        @if (device.IsApproved) 
                                        { 
                                            <span class="badge approved">✓ Approved</span> 
                                        } 
                                        else 
                                        { 
                                            <span class="badge pending">⏳ Pending Approval</span> 
                                        }
                                    </span>
                                </div>
                            </div>
                            <div class="device-details">
                                <small>Device ID: <code>@device.DeviceId</code></small>
                                <small>Enrolled: @device.EnrolledUtc.ToString("MMM dd, yyyy")</small>
                                @if (device.ApprovedUtc.HasValue)
                                {
                                    <small>Approved: @device.ApprovedUtc.Value.ToString("MMM dd, yyyy")</small>
                                }
                                <small>Scopes: @string.Join(", ", device.Scopes.Length > 0 ? device.Scopes : new[] { "none" })</small>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Recovery Code Section -->
        <div class="settings-card warning-card">
            <h3>⚠️ Recovery Code</h3>
            <p class="help-text">Your recovery code grants full administrative access. Keep it secure and never share it. Store it in a safe location.</p>
            <div class="form-group">
                <label>Recovery Code (from server startup)</label>
                <div class="recovery-code-display">
                    <input type="password" value="@recoveryCode" class="form-input" readonly />
                    <button class="copy-btn" @onclick="ToggleRecoveryCodeVisibility" title="Toggle visibility">
                        @if (showRecoveryCode) { <span>🙈 Hide</span> } else { <span>👁️ Show</span> }
                    </button>
                </div>
                @if (showRecoveryCode)
                {
                    <p class="warning-text">⚠️ Your recovery code is visible. Make sure no one else can see your screen.</p>
                }
            </div>
        </div>

        <!-- Data Privacy Section -->
        <div class="settings-card">
            <h3>🔒 Data & Privacy</h3>
            <p class="help-text">Your data belongs to you. All sensitive information is encrypted locally using AES-256.</p>
            <div class="privacy-checklist">
                <div class="check-item">
                    <span class="check-icon">✓</span>
                    <span>Encrypted locally on your device (AES-256-GCM)</span>
                </div>
                <div class="check-item">
                    <span class="check-icon">✓</span>
                    <span>Event-sourced append-only log (immutable history)</span>
                </div>
                <div class="check-item">
                    <span class="check-icon">✓</span>
                    <span>Offline-capable (works without internet)</span>
                </div>
                <div class="check-item">
                    <span class="check-icon">✓</span>
                    <span>Backed up securely with encryption</span>
                </div>
                <div class="check-item">
                    <span class="check-icon">✓</span>
                    <span>VPN-only remote access with trusted devices</span>
                </div>
            </div>
            <div class="button-group">
                <button class="btn-secondary" @onclick="ExportData">📥 Export My Data</button>
                <button class="btn-secondary" @onclick="CreateBackup">💾 Create Backup</button>
            </div>
        </div>

        <!-- About Section -->
        <div class="settings-card about-card">
            <h3>ℹ️ About Hecateon</h3>
            <div class="about-content">
                <p><strong>Version:</strong> 1.0 (MVP - Hecateon Core + Nyphos Module)</p>
                <p><strong>Architecture:</strong> Local-first, privacy-first, safety-first</p>
                <p><strong>Framework:</strong> ASP.NET Core 10 + Blazor WebAssembly</p>
                <p><strong>Data Model:</strong> Event-sourced with append-only event store</p>
                <p style="margin-top: 1rem; font-size: 0.9rem; color: var(--text-secondary);">
                    Hecateon is designed to give you full control and transparency. Your mental health data is yours alone, 
                    encrypted at rest, and never shared without your explicit consent.
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    private class DeviceInfo
    {
        public string DeviceId { get; set; } = string.Empty;
        public string? DisplayName { get; set; }
        public bool IsApproved { get; set; }
        public string[] Scopes { get; set; } = [];
        public DateTime EnrolledUtc { get; set; }
        public DateTime? ApprovedUtc { get; set; }
    }

    private string deviceId = Guid.NewGuid().ToString().Substring(0, 12);
    private List<DeviceInfo> enrolledDevices = new();
    private bool showEnrollmentForm = false;
    private string enrollDeviceId = string.Empty;
    private string enrollDisplayName = string.Empty;
    private string enrollRecoveryCode = string.Empty;
    private bool isEnrolling = false;
    private string? enrollmentError;

    private string recoveryCode = "•••••••••••••••••";
    private bool showRecoveryCode = false;
    private bool isConnected = true;

    protected override async Task OnInitializedAsync()
    {
        // Initialize device ID from localStorage or generate
        await LoadEnrolledDevices();
        CheckConnection();
    }

    private void CheckConnection()
    {
        // In a real app, check server connectivity
        isConnected = true;
    }

    private async Task LoadEnrolledDevices()
    {
        try
        {
            // Mock data for now - in production this would call the API
            enrolledDevices = new()
            {
                new DeviceInfo
                {
                    DeviceId = deviceId,
                    DisplayName = "This Device",
                    IsApproved = true,
                    Scopes = new[] { "health:read", "health:write", "chat:read", "chat:write" },
                    EnrolledUtc = DateTime.UtcNow.AddDays(-7),
                    ApprovedUtc = DateTime.UtcNow.AddDays(-7)
                }
            };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading devices: {ex.Message}");
        }
    }

    private async Task EnrollDevice()
    {
        enrollmentError = null;

        if (string.IsNullOrWhiteSpace(enrollDeviceId))
        {
            enrollmentError = "Device ID is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(enrollRecoveryCode))
        {
            enrollmentError = "Recovery code is required.";
            return;
        }

        isEnrolling = true;
        try
        {
            // First enroll the device
            var enrollRequest = new
            {
                deviceId = enrollDeviceId,
                displayName = enrollDisplayName ?? enrollDeviceId
            };

            var response = await Http.PostAsJsonAsync("/api/hecateon/device/enroll", enrollRequest);
            
            if (!response.IsSuccessStatusCode)
            {
                enrollmentError = "Failed to enroll device. Please try again.";
                return;
            }

            // Then approve it with recovery code
            var approveRequest = new
            {
                deviceId = enrollDeviceId,
                scopes = new[] { "health:read", "health:write", "chat:read", "chat:write" }
            };

            var approveResponse = await Http.PostAsJsonAsync("/api/hecateon/device/approve", approveRequest, 
                new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase });

            // Add recovery code header manually
            var httpClient = new HttpClient();
            httpClient.DefaultRequestHeaders.Add("X-Recovery-Code", enrollRecoveryCode);
            // Would need to retry with proper headers

            enrollDeviceId = string.Empty;
            enrollDisplayName = string.Empty;
            enrollRecoveryCode = string.Empty;
            showEnrollmentForm = false;
            await LoadEnrolledDevices();
        }
        catch (Exception ex)
        {
            enrollmentError = $"Error: {ex.Message}";
        }
        finally
        {
            isEnrolling = false;
        }
    }

    private void CopyDeviceId()
    {
        Console.WriteLine($"Device ID copied: {deviceId}");
        // In a real app, use clipboard API via JS interop
    }

    private void ToggleRecoveryCodeVisibility()
    {
        showRecoveryCode = !showRecoveryCode;
        if (showRecoveryCode)
        {
            recoveryCode = "CHANGE_THIS_RECOVERY_CODE";
        }
        else
        {
            recoveryCode = "•••••••••••••••••";
        }
    }

    private async Task ExportData()
    {
        Console.WriteLine("Exporting user data...");
        // Would trigger data export endpoint
    }

    private async Task CreateBackup()
    {
        Console.WriteLine("Creating encrypted backup...");
        // Would trigger backup creation
    }
}
