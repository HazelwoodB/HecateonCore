@page "/chat"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject HttpClient Http
@inject NavigationManager Navigation
@using System.Text.Json

<PageTitle>Chat - Lullaby</PageTitle>

<div class="chat-container">
    <!-- Header -->
    <div class="chat-header">
        <div class="header-content">
            <h2>💬 Chat</h2>
            <p class="subtitle">A safe space for your thoughts</p>
        </div>
        <div class="header-info">
            <span class="status-pill">
                @if (isOnline)
                {
                    <span class="status-dot online"></span>
                    <span>Connected</span>
                }
                else
                {
                    <span class="status-dot offline"></span>
                    <span>Offline</span>
                }
            </span>
        </div>
    </div>

    <!-- Messages Display -->
    <div class="messages-area" @ref="messagesContainer">
        @if (isLoadingMessages)
        {
            <div class="state-empty">
                <p>Loading your conversation...</p>
            </div>
        }
        else if (chatMessages.Count == 0)
        {
            <div class="state-empty">
                <p style="font-size: 2rem; margin: 0;">👋</p>
                <p style="font-weight: 600;">Welcome to Chat</p>
                <p>Start typing to begin a conversation. Everything you share stays private and encrypted.</p>
            </div>
        }
        else
        {
            @foreach (var msg in chatMessages)
            {
                <div class="message @(msg.IsUser ? "message-user" : "message-assistant")">
                    <div class="message-bubble">
                        @msg.Text
                    </div>
                    <div class="message-time">@msg.Timestamp:mm tt</div>
                </div>
            }

            @if (isWaitingForResponse)
            {
                <div class="message message-assistant">
                    <div class="message-bubble">
                        <span class="typing-indicator">
                            <span></span><span></span><span></span>
                        </span>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Input Area -->
    <div class="input-area">
        @if (!string.IsNullOrEmpty(lastError))
        {
            <div class="error-alert">
                <span>⚠️ @lastError</span>
                <button @onclick="() => lastError = string.Empty" class="error-close">×</button>
            </div>
        }
        
        <div class="input-container">
            <textarea 
                class="message-input"
                @bind="userInput"
                @onkeydown="HandleKeyPress"
                placeholder="Type your message... (Enter to send, Shift+Enter for new line)"
                disabled="@isWaitingForResponse"
                rows="2"></textarea>
            
            <button 
                class="send-btn"
                @onclick="SendMessageAsync"
                disabled="@(string.IsNullOrWhiteSpace(userInput) || isWaitingForResponse)">
                <span>Send</span>
            </button>
        </div>
    </div>
</div>

@code {
    private class Message
    {
        public string Id { get; set; } = Guid.NewGuid().ToString();
        public string Text { get; set; } = string.Empty;
        public bool IsUser { get; set; }
        public DateTime Timestamp { get; set; } = DateTime.Now;
    }

    private List<Message> chatMessages = new();
    private string userInput = string.Empty;
    private bool isLoadingMessages = false;
    private bool isWaitingForResponse = false;
    private bool isOnline = true;
    private string lastError = string.Empty;
    private ElementReference messagesContainer;

    protected override async Task OnInitializedAsync()
    {
        await LoadChatHistoryAsync();
    }

    private async Task LoadChatHistoryAsync()
    {
        isLoadingMessages = true;
        try
        {
            var response = await Http.GetAsync("/api/history?limit=50");
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                if (!string.IsNullOrWhiteSpace(json) && json != "[]")
                {
                    using var doc = JsonDocument.Parse(json);
                    var root = doc.RootElement;

                    if (root.ValueKind == JsonValueKind.Array)
                    {
                        foreach (var item in root.EnumerateArray().Reverse())
                        {
                            if (item.TryGetProperty("message", out var msgProp) &&
                                item.TryGetProperty("isUser", out var isUserProp))
                            {
                                chatMessages.Add(new Message
                                {
                                    Text = msgProp.GetString() ?? "(empty)",
                                    IsUser = isUserProp.GetBoolean(),
                                    Timestamp = DateTime.Now
                                });
                            }
                        }
                    }
                }
            }
            isOnline = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading history: {ex.Message}");
            isOnline = false;
        }
        finally
        {
            isLoadingMessages = false;
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessageAsync();
        }
    }

    private async Task SendMessageAsync()
    {
        if (string.IsNullOrWhiteSpace(userInput) || isWaitingForResponse)
            return;

        var messageText = userInput.Trim();
        userInput = string.Empty;

        // Add user message to UI immediately
        chatMessages.Add(new Message
        {
            Text = messageText,
            IsUser = true,
            Timestamp = DateTime.Now
        });

        isWaitingForResponse = true;
        lastError = string.Empty;

        try
        {
            // Send to server
            var request = new { message = messageText };
            var response = await Http.PostAsJsonAsync("/api/chat", request);

            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                using var doc = JsonDocument.Parse(json);
                var root = doc.RootElement;

                string reply = "(No response)";
                
                // Try different response formats
                if (root.TryGetProperty("reply", out var replyProp))
                {
                    reply = replyProp.GetString() ?? "(Empty reply)";
                }
                else if (root.TryGetProperty("message", out var msgProp))
                {
                    reply = msgProp.GetString() ?? "(Empty message)";
                }
                else if (root.ValueKind == JsonValueKind.String)
                {
                    reply = root.GetString() ?? "(Empty)";
                }

                // Add assistant response
                chatMessages.Add(new Message
                {
                    Text = reply,
                    IsUser = false,
                    Timestamp = DateTime.Now
                });
            }
            else
            {
                lastError = $"Server error: {response.StatusCode}";
                isOnline = false;
            }
        }
        catch (Exception ex)
        {
            lastError = "Connection failed - check if server is running";
            isOnline = false;
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            isWaitingForResponse = false;
        }
    }
}
