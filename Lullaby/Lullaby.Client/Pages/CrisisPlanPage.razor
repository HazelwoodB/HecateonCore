@page "/nyphos/crisis-plan"
@using Lullaby.Client
@using CrisisPlanModel = Lullaby.Client.CrisisPlan
@rendermode InteractiveWebAssembly
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Your Safety Circle</PageTitle>

<div class="crisis-plan-container">
    <div class="plan-header">
        <button class="btn-back" @onclick="GoBack">← Return to Guardian</button>
        <h1>🛟 Your Safety Circle</h1>
        <p class="plan-subtitle">Build your support network — gentle, clear, and entirely yours</p>
    </div>

    @if (_loading)
    {
        <div class="loading-state">
            <p>Gathering your safety circle...</p>
        </div>
    }
    else if (_plan is not null)
    {
        <div class="plan-content">
            <!-- Consent Settings -->
            <div class="plan-section consent-section">
                <h2>🤝 Your Boundaries</h2>
                <p class="section-note">You decide when and how support reaches you. These choices are always yours to change.</p>

                <div class="consent-options">
                    <label class="consent-toggle">
                        <input type="checkbox" @bind="_plan.AutoActivateOnRed" />
                        <span class="toggle-slider"></span>
                        <div class="toggle-label">
                            <strong>Show this circle automatically in deep red states</strong>
                            <p>Your safety circle will appear gently when your rhythm needs the most support.</p>
                        </div>
                    </label>

                    <label class="consent-toggle">
                        <input type="checkbox" @bind="_plan.AllowEmergencyContact" />
                        <span class="toggle-slider"></span>
                        <div class="toggle-label">
                            <strong>Allow gentle contact during crisis</strong>
                            <p>With your permission, trusted contacts can be quietly notified if you reach deep red.</p>
                        </div>
                    </label>
                </div>
            </div>

            <!-- Clinician Information -->
            <div class="plan-section clinician-section">
                <h2>🩺 Your Care Provider</h2>
                <p class="section-note">The professional who knows your story and can help when things feel impossible.</p>

                <div class="form-group">
                    <label>Provider Name</label>
                    <input type="text" @bind="_plan.ClinicianName" placeholder="Dr. Smith" class="form-control" />
                </div>

                <div class="form-group">
                    <label>Provider Phone</label>
                    <input type="tel" @bind="_plan.ClinicianPhone" placeholder="+1-555-1234" class="form-control" />
                </div>

                <div class="form-group">
                    <label>What to Say (if words feel hard)</label>
                    <p class="field-note">Write down what you need to say when speaking feels overwhelming:</p>
                    <textarea @bind="_plan.ClinicianScript" 
                              placeholder="'This is [your name]. I'm not okay right now and need help. Can you talk?'" 
                              rows="4"
                              class="form-control"></textarea>
                </div>
            </div>

            <!-- Support Contacts -->
            <div class="plan-section contacts-section">
                <h2>💫 Your Trusted People</h2>
                <p class="section-note">The friends or family who've earned your trust and can hold space when you're struggling.</p>

                @if (_plan.SupportContacts.Any())
                {
                    <div class="contacts-list">
                        @foreach (var contact in _plan.SupportContacts)
                        {
                            <div class="contact-card">
                                <div class="contact-header">
                                    <div class="contact-info">
                                        <strong>@contact.Name</strong>
                                        <span class="contact-relationship">@contact.Relationship</span>
                                    </div>
                                    <button class="btn-remove" @onclick="() => RemoveContact(contact.ContactId)">×</button>
                                </div>
                                <div class="contact-details">
                                    @if (!string.IsNullOrWhiteSpace(contact.Phone))
                                    {
                                        <p>📞 @contact.Phone</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(contact.Email))
                                    {
                                        <p>✉️ @contact.Email</p>
                                    }
                                    <label class="auto-contact-checkbox">
                                        <input type="checkbox" @bind="contact.CanAutoContact" />
                                        <span>They can be contacted during deep red states</span>
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                }

                @if (_showContactForm)
                {
                    <div class="contact-form">
                        <h3>Add a Trusted Person</h3>
                        <div class="form-group">
                            <label>Name</label>
                            <input type="text" @bind="_newContact.Name" placeholder="Jane Doe" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Relationship</label>
                            <input type="text" @bind="_newContact.Relationship" placeholder="Friend, Family, Therapist" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Phone (optional)</label>
                            <input type="tel" @bind="_newContact.Phone" placeholder="+1-555-5678" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Email (optional)</label>
                            <input type="email" @bind="_newContact.Email" placeholder="jane@example.com" class="form-control" />
                        </div>
                        <div class="form-actions">
                            <button class="btn-primary" @onclick="AddContact">Add to Circle</button>
                            <button class="btn-secondary" @onclick="() => _showContactForm = false">Not Now</button>
                        </div>
                    </div>
                }
                else
                {
                    <button class="btn-add" @onclick="() => _showContactForm = true">+ Add a Trusted Person</button>
                }
            </div>

            <!-- Safety Steps -->
            <div class="plan-section steps-section">
                <h2>🌿 Your Personal Safety Steps</h2>
                <p class="section-note">What helps you find ground when everything feels impossible? Build your own gentle path through crisis.</p>

                @if (_plan.SafetySteps.Any())
                {
                    <div class="steps-list">
                        @foreach (var step in _plan.SafetySteps.OrderBy(s => s.Order))
                        {
                            <div class="step-card">
                                <div class="step-number">@step.Order</div>
                                <div class="step-content">
                                    <p class="step-description">@step.Description</p>
                                    @if (!string.IsNullOrWhiteSpace(step.Details))
                                    {
                                        <p class="step-details">@step.Details</p>
                                    }
                                </div>
                                <button class="btn-remove-step" @onclick="() => RemoveStep(step.StepId)">×</button>
                            </div>
                        }
                    </div>
                }

                @if (_showStepForm)
                {
                    <div class="step-form">
                        <h3>Add a Safety Step</h3>
                        <div class="form-group">
                            <label>What helps you?</label>
                            <input type="text" @bind="_newStepDescription" placeholder="Go somewhere quiet and safe" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Details (if helpful)</label>
                            <textarea @bind="_newStepDetails" placeholder="My bedroom with door closed, or the bench by the lake" rows="2" class="form-control"></textarea>
                        </div>
                        <div class="form-actions">
                            <button class="btn-primary" @onclick="AddStep">Add Step</button>
                            <button class="btn-secondary" @onclick="() => _showStepForm = false">Not Now</button>
                        </div>
                    </div>
                }
                else
                {
                    <button class="btn-add" @onclick="() => _showStepForm = true">+ Add a Safety Step</button>
                }
            </div>

            <!-- Crisis Resources (Always Available) -->
            <div class="plan-section resources-section">
                <h2>🆘 Always-Available Lifelines</h2>
                <p class="section-note">These resources exist for everyone, any time, no questions asked. You don't need permission to use them.</p>

                <div class="crisis-resources-grid">
                    <div class="resource-card">
                        <h3>988 Suicide & Crisis Lifeline</h3>
                        <p><strong>Call or Text: 988</strong></p>
                        <p>24/7 support for people in distress</p>
                        <a href="https://988lifeline.org" target="_blank">988lifeline.org</a>
                    </div>

                    <div class="resource-card">
                        <h3>Crisis Text Line</h3>
                        <p><strong>Text HOME to 741741</strong></p>
                        <p>Free 24/7 text support</p>
                        <a href="https://www.crisistextline.org" target="_blank">crisistextline.org</a>
                    </div>

                    <div class="resource-card">
                        <h3>Emergency Services</h3>
                        <p><strong>Call: 911</strong></p>
                        <p>Immediate life-threatening emergencies</p>
                    </div>
                </div>
            </div>

            <!-- Save Changes -->
            <div class="save-section">
                <button class="btn-save" @onclick="SavePlan">Save Your Safety Circle</button>
                <p class="save-note">Your information is stored locally and encrypted</p>
            </div>
        </div>
    }
    else
    {
        <div class="no-plan">
            <h2>Let's Build Your Safety Circle</h2>
            <p>Creating a safety plan helps you prepare for difficult moments before they happen. It's a tool you control.</p>
            <button class="btn-primary" @onclick="CreateNewPlan">Start Building</button>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private CrisisPlanModel? _plan;
    private bool _showContactForm = false;
    private bool _showStepForm = false;
    private SupportContact _newContact = new();
    private string _newStepDescription = string.Empty;
    private string _newStepDetails = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadPlanAsync();
    }

    private async Task LoadPlanAsync()
    {
        _loading = true;
        try
        {
            _plan = CreateSamplePlan();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading crisis plan: {ex.Message}");
            _plan = null;
        }
        finally
        {
            _loading = false;
        }
    }

    private CrisisPlanModel CreateSamplePlan()
    {
        return new CrisisPlanModel
        {
            PlanId = Guid.NewGuid(),
            CreatedAtUtc = DateTime.UtcNow.AddDays(-30),
            LastUpdatedAtUtc = DateTime.UtcNow,
            AutoActivateOnRed = true,
            AllowEmergencyContact = false,
            ClinicianName = "Dr. Sarah Chen",
            ClinicianPhone = "+1-555-0123",
            ClinicianScript = "Hi, this is [name]. I'm experiencing a mental health crisis and need support. Can we talk?",
            SupportContacts = new List<SupportContact>
            {
                new()
                {
                    ContactId = Guid.NewGuid(),
                    Name = "Alex",
                    Relationship = "Friend",
                    Phone = "+1-555-0456",
                    Email = "alex@example.com",
                    CanAutoContact = false
                }
            },
            SafetySteps = new List<SafetyStep>
            {
                new()
                {
                    StepId = Guid.NewGuid(),
                    Order = 1,
                    Description = "Find a quiet, safe space",
                    Details = "My bedroom with the door closed, or the park bench by the pond"
                },
                new()
                {
                    StepId = Guid.NewGuid(),
                    Order = 2,
                    Description = "Focus on breathing",
                    Details = "4-7-8 breathing: In for 4, hold for 7, out for 8"
                },
                new()
                {
                    StepId = Guid.NewGuid(),
                    Order = 3,
                    Description = "Call my therapist or support person",
                    Details = "Use the script I prepared if words feel hard"
                }
            }
        };
    }

    private void CreateNewPlan()
    {
        _plan = new CrisisPlanModel
        {
            PlanId = Guid.NewGuid(),
            CreatedAtUtc = DateTime.UtcNow,
            LastUpdatedAtUtc = DateTime.UtcNow,
            AutoActivateOnRed = true,
            AllowEmergencyContact = false
        };
    }

    private void RemoveContact(Guid contactId)
    {
        if (_plan is null) return;
        var contact = _plan.SupportContacts.FirstOrDefault(c => c.ContactId == contactId);
        if (contact is not null)
        {
            _plan.SupportContacts.Remove(contact);
        }
    }

    private void AddContact()
    {
        if (_plan is null || string.IsNullOrWhiteSpace(_newContact.Name)) return;

        _newContact.ContactId = Guid.NewGuid();
        _plan.SupportContacts.Add(_newContact);
        _newContact = new SupportContact();
        _showContactForm = false;
    }

    private void RemoveStep(Guid stepId)
    {
        if (_plan is null) return;
        var step = _plan.SafetySteps.FirstOrDefault(s => s.StepId == stepId);
        if (step is not null)
        {
            _plan.SafetySteps.Remove(step);
            var orderedSteps = _plan.SafetySteps.OrderBy(s => s.Order).ToList();
            for (int i = 0; i < orderedSteps.Count; i++)
            {
                orderedSteps[i].Order = i + 1;
            }
        }
    }

    private void AddStep()
    {
        if (_plan is null || string.IsNullOrWhiteSpace(_newStepDescription)) return;

        var newStep = new SafetyStep
        {
            StepId = Guid.NewGuid(),
            Order = _plan.SafetySteps.Any() ? _plan.SafetySteps.Max(s => s.Order) + 1 : 1,
            Description = _newStepDescription,
            Details = string.IsNullOrWhiteSpace(_newStepDetails) ? null : _newStepDetails
        };

        _plan.SafetySteps.Add(newStep);
        _newStepDescription = string.Empty;
        _newStepDetails = string.Empty;
        _showStepForm = false;
    }

    private async Task SavePlan()
    {
        if (_plan is null) return;

        try
        {
            _plan.LastUpdatedAtUtc = DateTime.UtcNow;
            Console.WriteLine("Crisis plan saved successfully");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving crisis plan: {ex.Message}");
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/nyphos");
    }
}
