@page "/nyphos/test"
@using Lullaby.Client
@rendermode InteractiveWebAssembly
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Nyphos Testing</PageTitle>

<div class="test-container">
    <div class="test-header">
        <h1>🧪 Nyphos Test Data Generator</h1>
        <p>Generate sample health events to test different risk states</p>
        <button class="btn-back" @onclick="GoBack">← Back to Dashboard</button>
    </div>

    @if (_loading)
    {
        <div class="loading">
            <div class="spinner"></div>
            <p>Generating test data...</p>
        </div>
    }

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="message @(_isError ? "error" : "success")">
            @_message
        </div>
    }

    <div class="test-scenarios">
        <h2>📊 Single State Scenarios</h2>
        <p class="scenario-desc">Generate 7 days of data for a specific state (overwrites existing data)</p>
        
        <div class="scenario-grid">
            <div class="scenario-card state-green">
                <div class="scenario-header">
                    <span class="scenario-icon">✅</span>
                    <h3>Green State</h3>
                </div>
                <p class="scenario-details">
                    • 7-8 hours sleep/night<br/>
                    • Quality: 4/5<br/>
                    • Stable mood (7/10)<br/>
                    • Regular routines
                </p>
                <button class="btn-generate" @onclick='() => GenerateScenario("green")' disabled="@_loading">
                    Generate Green Data
                </button>
            </div>

            <div class="scenario-card state-yellow">
                <div class="scenario-header">
                    <span class="scenario-icon">⚠️</span>
                    <h3>Yellow State</h3>
                </div>
                <p class="scenario-details">
                    • 5.5-6 hours sleep/night<br/>
                    • Quality: 2-3/5<br/>
                    • Declining mood (5-6/10)<br/>
                    • Some missed routines
                </p>
                <button class="btn-generate" @onclick='() => GenerateScenario("yellow")' disabled="@_loading">
                    Generate Yellow Data
                </button>
            </div>

            <div class="scenario-card state-orange">
                <div class="scenario-header">
                    <span class="scenario-icon">🟠</span>
                    <h3>Orange State</h3>
                </div>
                <p class="scenario-details">
                    • &lt;5 hours sleep/night<br/>
                    • Quality: 1-2/5<br/>
                    • Elevated mood (9/10)<br/>
                    • Disrupted routines<br/>
                    • ⚠️ Manic indicators
                </p>
                <button class="btn-generate" @onclick='() => GenerateScenario("orange")' disabled="@_loading">
                    Generate Orange Data
                </button>
            </div>

            <div class="scenario-card state-red">
                <div class="scenario-header">
                    <span class="scenario-icon">🚨</span>
                    <h3>Red State</h3>
                </div>
                <p class="scenario-details">
                    • &lt;4 hours sleep/night<br/>
                    • Quality: 1/5<br/>
                    • Volatile mood (4-10/10)<br/>
                    • No routines<br/>
                    • 🚨 Crisis indicators
                </p>
                <button class="btn-generate" @onclick='() => GenerateScenario("red")' disabled="@_loading">
                    Generate Red Data
                </button>
            </div>
        </div>
    </div>

    <div class="test-scenarios">
        <h2>🔄 State Transition Scenario</h2>
        <p class="scenario-desc">Tests hysteresis with 14 days showing progression through states</p>
        
        <div class="scenario-card state-transition">
            <div class="scenario-header">
                <span class="scenario-icon">📈</span>
                <h3>Full State Progression</h3>
            </div>
            <p class="scenario-details">
                Day 14-10: <strong>Green</strong> (stable baseline)<br/>
                Day 9-7: <strong>Yellow</strong> (decline)<br/>
                Day 6-4: <strong>Orange</strong> (worsening)<br/>
                Day 3-1: <strong>Yellow</strong> (brief improvement - tests hysteresis cooldown)<br/>
                Day 0: <strong>Green</strong> (recovery)
            </p>
            <button class="btn-generate" @onclick='() => GenerateScenario("transitions")' disabled="@_loading">
                Generate Transition Data
            </button>
        </div>
    </div>

    <div class="test-actions">
        <h2>🗑️ Data Management</h2>
        <button class="btn-danger" @onclick="ClearData" disabled="@_loading">
            Clear All Test Data
        </button>
        <p class="warning-text">⚠️ This will delete all health events, state history, and protocols</p>
    </div>

    <div class="test-info">
        <h3>ℹ️ Testing Tips</h3>
        <ul>
            <li><strong>Start with Green:</strong> Baseline state shows dashboard with good scores</li>
            <li><strong>Progress to Yellow:</strong> Shows attention warnings and declining metrics</li>
            <li><strong>Test Orange:</strong> Activates Downshift Protocol, shows intervention UI</li>
            <li><strong>Test Red:</strong> Crisis resources highlighted, high-priority interventions</li>
            <li><strong>Test Transitions:</strong> Validates hysteresis (cooldown periods prevent rapid state changes)</li>
        </ul>
    </div>
</div>

@code {
    private bool _loading = false;
    private string _message = string.Empty;
    private bool _isError = false;

    private async Task GenerateScenario(string scenario)
    {
        _loading = true;
        _message = string.Empty;
        _isError = false;

        try
        {
            // Clear existing data first
            await Http.DeleteAsync("/api/test/clear-data");
            await Task.Delay(500); // Give file system time to release

            // Generate new scenario
            var endpoint = scenario switch
            {
                "green" => "/api/test/generate-green",
                "yellow" => "/api/test/generate-yellow",
                "orange" => "/api/test/generate-orange",
                "red" => "/api/test/generate-red",
                "transitions" => "/api/test/generate-transitions",
                _ => throw new ArgumentException($"Unknown scenario: {scenario}")
            };

            var response = await Http.PostAsync(endpoint, null);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<TestDataResponse>();
                _message = $"✅ {result?.Message ?? "Test data generated successfully"}";
                _isError = false;

                // Wait a moment then navigate to dashboard
                await Task.Delay(1500);
                Navigation.NavigateTo("/nyphos", forceLoad: true);
            }
            else
            {
                _message = "❌ Failed to generate test data";
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = $"❌ Error: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ClearData()
    {
        if (!await ConfirmClear()) return;

        _loading = true;
        _message = string.Empty;
        _isError = false;

        try
        {
            var response = await Http.DeleteAsync("/api/test/clear-data");
            if (response.IsSuccessStatusCode)
            {
                _message = "✅ All test data cleared";
                _isError = false;
            }
            else
            {
                _message = "❌ Failed to clear data";
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = $"❌ Error: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task<bool> ConfirmClear()
    {
        // In a real app, use a proper confirmation modal
        // For now, just proceed (since this is a test page)
        await Task.CompletedTask;
        return true;
    }

    private void GoBack() => Navigation.NavigateTo("/nyphos");

    private class TestDataResponse
    {
        public string Message { get; set; } = string.Empty;
    }
}
