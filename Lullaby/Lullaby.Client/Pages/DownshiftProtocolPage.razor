@page "/nyphos/downshift"
@using Hecateon.Client
@rendermode InteractiveWebAssembly
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Gentle Slowdown</PageTitle>

<div class="downshift-container">
    <div class="protocol-header">
        <button class="btn-back" @onclick="GoBack">← Return to Guardian</button>
        <h1>🌙 Gentle Slowdown Protocol</h1>
        <p class="protocol-subtitle">Let's ease the pace together. Restore your rhythm. Find steady ground.</p>
    </div>

    @if (_loading)
    {
        <div class="loading-state">
            <p>Preparing your gentle slowdown space...</p>
        </div>
    }
    else if (_protocol is not null)
    {
        <div class="protocol-status-card">
            <div class="status-info">
                <p><strong>We began this together:</strong> @_protocol.ActivatedAtUtc.ToLocalTime().ToString("MMM d, yyyy 'at' h:mm tt")</p>
                <p><strong>What brought us here:</strong> <span class="state-badge state-@_protocol.TriggeringState.ToString().ToLowerInvariant()">@GetStatePhrase(_protocol.TriggeringState)</span></p>
                @if (_protocol.CompletedAtUtc.HasValue)
                {
                    <p><strong>You completed this:</strong> @_protocol.CompletedAtUtc.Value.ToLocalTime().ToString("MMM d, yyyy 'at' h:mm tt")</p>
                }
            </div>
        </div>

        <!-- Checklist -->
        <div class="checklist-section">
            <h2>🌿 Steps to Steady Ground</h2>
            <p class="checklist-intro">These are gentle suggestions, not demands. Move through them at your own pace. There's no rush.</p>

            <div class="checklist-items">
                @foreach (var item in _protocol.ChecklistItems.OrderBy(i => i.Priority))
                {
                    <div class="checklist-item @(item.IsCompleted ? "completed" : "")">
                        <div class="item-checkbox">
                            <input type="checkbox" 
                                   checked="@item.IsCompleted" 
                                   @onchange="() => ToggleItem(item)"
                                   id="item-@item.ItemId" />
                            <label for="item-@item.ItemId"></label>
                        </div>
                        <div class="item-content">
                            <div class="item-header">
                                <span class="item-priority">Step @item.Priority</span>
                                <span class="item-category">@item.Category</span>
                            </div>
                            <p class="item-description">@item.Description</p>
                            @if (item.IsCompleted && item.CompletedAtUtc.HasValue)
                            {
                                <p class="item-completed-time">
                                    ✓ You did this at @item.CompletedAtUtc.Value.ToLocalTime().ToString("h:mm tt")
                                </p>
                            }
                            @if (!item.IsCompleted && _expandedItemId == item.ItemId)
                            {
                                <div class="item-note-section">
                                    <textarea @bind="_itemNote" 
                                              placeholder="Write anything that helps... (completely optional)" 
                                              rows="2"
                                              class="item-note-input"></textarea>
                                </div>
                            }
                        </div>
                        @if (!item.IsCompleted)
                        {
                            <button class="btn-expand" @onclick="() => ToggleExpand(item.ItemId)">
                                @(_expandedItemId == item.ItemId ? "−" : "+")
                            </button>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Decision Delays -->
        <div class="decision-delays-section">
            <h2>⏸️ Pausing Big Decisions</h2>
            <p class="section-intro">When the world feels urgent, we can pause. Write down any major decisions you're choosing to revisit in 2-3 days, when your rhythm is steadier.</p>

            @if (_showDelayForm)
            {
                <div class="delay-form">
                    <textarea @bind="_delayDescription" 
                              placeholder="What are you choosing to wait on? (e.g., 'Starting a new project', 'Having a difficult conversation')" 
                              rows="3"
                              class="delay-input"></textarea>
                    <div class="delay-duration">
                        <label>Revisit after:</label>
                        <select @bind="_delayHours" class="delay-select">
                            <option value="48">48 hours</option>
                            <option value="72">72 hours (gentle default)</option>
                            <option value="96">96 hours</option>
                        </select>
                    </div>
                    <div class="delay-actions">
                        <button class="btn-primary" @onclick="SaveDelay">Save This Pause</button>
                        <button class="btn-secondary" @onclick="() => _showDelayForm = false">Not Now</button>
                    </div>
                </div>
            }
            else
            {
                <button class="btn-add" @onclick="() => _showDelayForm = true">+ Pause a Decision</button>
            }

            @if (_protocol.DelayedDecisions.Any())
            {
                <div class="delayed-decisions-list">
                    @foreach (var decision in _protocol.DelayedDecisions.OrderByDescending(d => d.LoggedAtUtc))
                    {
                        <div class="delayed-decision-item">
                            <div class="decision-header">
                                <strong>@decision.Description</strong>
                                <span class="decision-review-date">You can revisit after @decision.ReviewAfterUtc.ToLocalTime().ToString("MMM d, h:mm tt")</span>
                            </div>
                            @if (decision.WasReviewed)
                            {
                                <p class="decision-outcome">
                                    ✓ You reviewed this: @decision.ReviewOutcome
                                </p>
                            }
                            else if (DateTime.UtcNow >= decision.ReviewAfterUtc)
                            {
                                <p class="decision-ready">Ready when you are</p>
                            }
                            else
                            {
                                <p class="decision-countdown">
                                    Time remaining: @FormatTimeRemaining(decision.ReviewAfterUtc - DateTime.UtcNow)
                                </p>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Feedback Section -->
        @if (!_protocol.CompletedAtUtc.HasValue && _completionPercentage >= 80)
        {
            <div class="feedback-section">
                <h2>💬 How Are You Feeling?</h2>
                <p>You've moved through most of these steps. If you'd like, share what's been helpful or what hasn't worked:</p>
                <textarea @bind="_feedbackText" 
                          placeholder="Whatever you'd like to share..." 
                          rows="4"
                          class="feedback-input"></textarea>
                <div class="feedback-actions">
                    <button class="btn-helpful" @onclick="() => SubmitFeedback(true)">✓ This helped me</button>
                    <button class="btn-not-helpful" @onclick="() => SubmitFeedback(false)">This wasn't helpful</button>
                </div>
            </div>
        }
    }
    else
    {
        <div class="no-protocol">
            <h2>No Active Slowdown</h2>
            <p>The Gentle Slowdown can be activated from your Guardian dashboard when your rhythm needs extra support (amber or deep red states).</p>
            <button class="btn-primary" @onclick="GoBack">Return to Guardian</button>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private DownshiftProtocol? _protocol;
    private Guid? _expandedItemId;
    private string _itemNote = string.Empty;
    private bool _showDelayForm = false;
    private string _delayDescription = string.Empty;
    private int _delayHours = 72;
    private string _feedbackText = string.Empty;
    private int _completionPercentage = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadProtocolAsync();
    }

    private async Task LoadProtocolAsync()
    {
        _loading = true;
        try
        {
            // In a real implementation, we'd fetch the most recent active protocol
            // For now, we'll create a sample protocol
            _protocol = await CreateSampleProtocol();
            CalculateCompletionPercentage();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading protocol: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task<DownshiftProtocol> CreateSampleProtocol()
    {
        // This would normally come from the API
        // For now, activate a new one
        try
        {
            var response = await Http.PostAsJsonAsync("/api/downshift/activate", new { TriggeringState = NyphosRiskState.Orange });
            if (response.IsSuccessStatusCode)
            {
                return await response.Content.ReadFromJsonAsync<DownshiftProtocol>() ?? new DownshiftProtocol();
            }
        }
        catch { }
        
        return new DownshiftProtocol { TriggeringState = NyphosRiskState.Orange };
    }

    private async Task ToggleItem(DownshiftItem item)
    {
        item.IsCompleted = !item.IsCompleted;
        item.CompletedAtUtc = item.IsCompleted ? DateTime.UtcNow : null;
        item.CompletionNote = item.IsCompleted ? _itemNote : null;

        try
        {
            await Http.PostAsJsonAsync($"/api/downshift/{_protocol!.ProtocolId}/complete-item", 
                new { ItemId = item.ItemId, Note = _itemNote });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error toggling item: {ex.Message}");
        }

        _itemNote = string.Empty;
        _expandedItemId = null;
        CalculateCompletionPercentage();
    }

    private void ToggleExpand(Guid itemId)
    {
        _expandedItemId = _expandedItemId == itemId ? null : itemId;
        _itemNote = string.Empty;
    }

    private async Task SaveDelay()
    {
        if (string.IsNullOrWhiteSpace(_delayDescription)) return;

        var decision = new DelayedDecision
        {
            Description = _delayDescription,
            LoggedAtUtc = DateTime.UtcNow,
            ReviewAfterUtc = DateTime.UtcNow.AddHours(_delayHours)
        };

        _protocol!.DelayedDecisions.Add(decision);

        try
        {
            await Http.PostAsJsonAsync($"/api/downshift/{_protocol.ProtocolId}/delay-decision",
                new { Description = _delayDescription, HoursToDelay = _delayHours });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving delay: {ex.Message}");
        }

        _delayDescription = string.Empty;
        _delayHours = 72;
        _showDelayForm = false;
    }

    private async Task SubmitFeedback(bool wasHelpful)
    {
        try
        {
            await Http.PostAsJsonAsync($"/api/downshift/{_protocol!.ProtocolId}/feedback",
                new { Feedback = _feedbackText, WasHelpful = wasHelpful });
            
            _protocol.CompletedAtUtc = DateTime.UtcNow;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error submitting feedback: {ex.Message}");
        }
    }

    private void CalculateCompletionPercentage()
    {
        if (_protocol is null || !_protocol.ChecklistItems.Any()) return;
        
        var completed = _protocol.ChecklistItems.Count(i => i.IsCompleted);
        _completionPercentage = (int)((completed / (double)_protocol.ChecklistItems.Count) * 100);
    }

    private string FormatTimeRemaining(TimeSpan remaining)
    {
        if (remaining.TotalDays >= 1)
            return $"{(int)remaining.TotalDays} day{((int)remaining.TotalDays != 1 ? "s" : "")}";
        if (remaining.TotalHours >= 1)
            return $"{(int)remaining.TotalHours} hour{((int)remaining.TotalHours != 1 ? "s" : "")}";
        return $"{(int)remaining.TotalMinutes} minute{((int)remaining.TotalMinutes != 1 ? "s" : "")}";
    }

    private void GoBack() => Navigation.NavigateTo("/nyphos");

    private string GetStatePhrase(NyphosRiskState state)
    {
        return state switch
        {
            NyphosRiskState.Orange => "Amber — needing slowdown",
            NyphosRiskState.Red => "Deep Red — crisis support",
            _ => state.ToString()
        };
    }
}
