@page "/nyphos"
@using Lullaby.Client
@rendermode InteractiveWebAssembly
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Nyphos - Guardian of Rhythm</PageTitle>

<div class="nyphos-container">
    <!-- Poetic Header -->
    <div class="guardian-header">
        <div class="moon-icon">🌙</div>
        <div class="guardian-identity">
            <h1>Nyphos</h1>
            <p class="guardian-title">Guardian of Rhythm</p>
            <p class="guardian-whisper">I notice patterns you might miss</p>
        </div>
    </div>

    @if (_loading)
    {
        <div class="loading-state">
            <div class="pulse-circle"></div>
            <p class="loading-text">Observing your patterns...</p>
        </div>
    }
    else if (_assessment is not null)
    {
        <!-- Gentle State Banner -->
        <div class="rhythm-banner state-@_assessment.CurrentState.ToString().ToLowerInvariant()">
            <div class="rhythm-glow"></div>
            <div class="rhythm-content">
                <div class="state-symbol">@GetStateSymbol(_assessment.CurrentState)</div>
                <div class="state-message">
                    <h2 class="state-name">@GetStateName(_assessment.CurrentState)</h2>
                    <p class="state-voice">@_assessment.StateExplanation</p>
                    @if (_assessment.TimeSinceLastTransition.HasValue)
                    {
                        <p class="rhythm-duration">
                            <span class="rhythm-label">Rhythm held for</span> @FormatDuration(_assessment.TimeSinceLastTransition.Value)
                            @if (!_assessment.IsStableState)
                            {
                                <span class="settling-notice"> · Settling... @FormatDuration(_assessment.MinimumCooldown - _assessment.TimeSinceLastTransition.Value)</span>
                            }
                        </p>
                    }
                </div>
            </div>
        </div>

        <!-- Pattern Observations -->
        <div class="observations-section">
            <h3 class="section-title">
                <span class="section-icon">👁️</span>
                What I Notice (Last @_assessment.DaysAnalyzed Days)
            </h3>
            <div class="pattern-grid">
                <!-- Sleep Pattern -->
                <div class="pattern-card pattern-sleep">
                    <div class="pattern-header">
                        <span class="pattern-icon">🌙</span>
                        <span class="pattern-name">Sleep</span>
                    </div>
                    <div class="pattern-score score-@GetScoreLevel(_assessment.SleepScore)">
                        @(_assessment.SleepScore.ToString("P0"))
                    </div>
                    <p class="pattern-observation">@_assessment.SleepExplanation</p>
                    <span class="pattern-trend trend-@_assessment.SleepTrend.ToString().ToLowerInvariant()">
                        @GetTrendSymbol(_assessment.SleepTrend.ToString()) @_assessment.SleepTrend
                    </span>
                </div>

                <!-- Mood Pattern -->
                <div class="pattern-card pattern-mood">
                    <div class="pattern-header">
                        <span class="pattern-icon">💫</span>
                        <span class="pattern-name">Mood</span>
                    </div>
                    <div class="pattern-score score-@GetScoreLevel(_assessment.MoodScore)">
                        @(_assessment.MoodScore.ToString("P0"))
                    </div>
                    <p class="pattern-observation">@_assessment.MoodExplanation</p>
                    <span class="pattern-trend trend-@_assessment.MoodTrend.ToString().ToLowerInvariant()">
                        @GetTrendSymbol(_assessment.MoodTrend.ToString()) @_assessment.MoodTrend
                    </span>
                </div>

                <!-- Routine Pattern -->
                <div class="pattern-card pattern-routine">
                    <div class="pattern-header">
                        <span class="pattern-icon">⏰</span>
                        <span class="pattern-name">Routine</span>
                    </div>
                    <div class="pattern-score score-@GetScoreLevel(_assessment.RoutineScore)">
                        @(_assessment.RoutineScore.ToString("P0"))
                    </div>
                    <p class="pattern-observation">@_assessment.RoutineExplanation</p>
                </div>

                <!-- Activity Pattern -->
                <div class="pattern-card pattern-activity">
                    <div class="pattern-header">
                        <span class="pattern-icon">✨</span>
                        <span class="pattern-name">Activity</span>
                    </div>
                    <div class="pattern-score score-@GetScoreLevel(_assessment.ActivityScore)">
                        @(_assessment.ActivityScore.ToString("P0"))
                    </div>
                    <p class="pattern-observation">@_assessment.ActivityExplanation</p>
                </div>
            </div>
        </div>

        <!-- Contributing Factors (Gentle) -->
        @if (_assessment.ContributingFactors.Any())
        {
            <div class="factors-section">
                <h3 class="section-title">
                    <span class="section-icon">🔍</span>
                    Patterns I'm Watching
                </h3>
                <div class="factors-list">
                    @foreach (var factor in _assessment.ContributingFactors.Take(5))
                    {
                        <div class="factor-item">
                            <div class="factor-importance" style="width: @((factor.Weight * 100).ToString("F0"))%"></div>
                            <div class="factor-content">
                                <span class="factor-name">@factor.Factor</span>
                                <span class="factor-category">@factor.Category</span>
                            </div>
                            <p class="factor-note">@factor.Explanation</p>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Gentle Suggestions (Not Commands) -->
        @if (_assessment.RecommendedActions.Any())
        {
            <div class="suggestions-section">
                <h3 class="section-title">
                    <span class="section-icon">💭</span>
                    Gentle Suggestions
                </h3>
                <p class="section-subtitle">You know yourself best. These are just observations.</p>
                <div class="suggestions-list">
                    @foreach (var action in _assessment.RecommendedActions)
                    {
                        <div class="suggestion-item">
                            <span class="suggestion-icon">◆</span>
                            <span class="suggestion-text">@action</span>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Downshift Protocol (Orange/Red - Protective, Not Controlling) -->
        @if (_assessment.CurrentState >= NyphosRiskState.Orange)
        {
            <div class="protection-section">
                <h3 class="section-title">
                    <span class="section-icon">🛡️</span>
                    Protective Protocol
                </h3>
                <p class="protection-message">
                    I notice momentum building. Would you like help slowing it gently?
                </p>
                @if (_assessment.DownshiftProtocolActive)
                {
                    <p class="protocol-active">
                        Protocol active since @_assessment.DownshiftActivatedAtUtc?.ToLocalTime().ToString("MMM d, h:mm tt")
                    </p>
                    <button class="btn-gentle" @onclick="ViewDownshiftProtocol">View My Checklist</button>
                }
                else
                {
                    <button class="btn-gentle-primary" @onclick="ActivateDownshiftProtocol">Help Me Slow Down</button>
                }
            </div>
        }

        <!-- Crisis Resources (Always Accessible, Never Alarming) -->
        <div class="support-section @(_assessment.CurrentState == NyphosRiskState.Red ? "support-highlighted" : "")">
            <h3 class="section-title">
                <span class="section-icon">🤝</span>
                Support Resources
            </h3>
            <p class="support-message">Always here, no judgment.</p>
            <div class="support-grid">
                <a href="tel:988" class="support-card">
                    <span class="support-icon">📞</span>
                    <div class="support-info">
                        <strong>988 Lifeline</strong>
                        <p>24/7 support</p>
                    </div>
                </a>
                <a href="tel:911" class="support-card">
                    <span class="support-icon">🚑</span>
                    <div class="support-info">
                        <strong>911 Emergency</strong>
                        <p>Immediate help</p>
                    </div>
                </a>
                <a href="sms:741741?body=HELLO" class="support-card">
                    <span class="support-icon">💬</span>
                    <div class="support-info">
                        <strong>Crisis Text Line</strong>
                        <p>Text HELLO to 741741</p>
                    </div>
                </a>
            </div>
            <button class="btn-subtle" @onclick="ManageCrisisPlan">Manage My Support Plan</button>
        </div>
    }

    <!-- Quick Actions (Gentle Prompts) -->
    <div class="actions-section">
        <h3 class="section-title">
            <span class="section-icon">✍️</span>
            Quick Log
        </h3>
        <div class="actions-grid">
            <button class="action-btn" @onclick="() => ShowLogDialog(HealthEventType.Sleep)">
                <span class="action-icon">🌙</span>
                <span>Sleep</span>
            </button>
            <button class="action-btn" @onclick="() => ShowLogDialog(HealthEventType.Mood)">
                <span class="action-icon">💫</span>
                <span>Mood</span>
            </button>
            <button class="action-btn" @onclick="() => ShowLogDialog(HealthEventType.Routine)">
                <span class="action-icon">⏰</span>
                <span>Routine</span>
            </button>
            <button class="action-btn" @onclick="ViewHistory">
                <span class="action-icon">📖</span>
                <span>History</span>
            </button>
        </div>
    </div>

    <!-- Gentle Modal (same logging modal, just update later) -->
    @if (_showLogDialog)
    {
        <div class="modal-overlay" @onclick="CloseLogDialog">
            <div class="modal-dialog" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h3>Log @_currentLogType</h3>
                    <button class="btn-close" @onclick="CloseLogDialog">×</button>
                </div>
                
                <div class="modal-body">
                    @if (_currentLogType == HealthEventType.Sleep)
                    {
                        <div class="form-group">
                            <label>Sleep Start</label>
                            <input type="datetime-local" @bind="_sleepStart" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Sleep End</label>
                            <input type="datetime-local" @bind="_sleepEnd" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Sleep Quality (1-5)</label>
                            <div class="quality-selector">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    var quality = i;
                                    <button class="quality-btn @(_newEvent.SleepQuality == quality ? "selected" : "")"
                                            @onclick="() => _newEvent.SleepQuality = quality">
                                        @quality
                                    </button>
                                }
                            </div>
                        </div>
                    }
                    else if (_currentLogType == HealthEventType.Mood)
                    {
                        <div class="form-group">
                            <label>Mood Score (1-10)</label>
                            <input type="range" min="1" max="10" @bind="_newEvent.MoodScore" class="form-range" />
                            <span class="range-value">@_newEvent.MoodScore</span>
                        </div>
                        <div class="form-group">
                            <label>How would you describe it?</label>
                            <input type="text" @bind="_newEvent.MoodLabel" placeholder="e.g., Calm, Energized, Low" class="form-control" />
                        </div>
                    }
                    else if (_currentLogType == HealthEventType.Routine)
                    {
                        <div class="form-group">
                            <label>Routine Name</label>
                            <input type="text" @bind="_newEvent.RoutineName" placeholder="e.g., Morning Routine" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>
                                <input type="checkbox" @bind="_newEvent.RoutineCompleted" />
                                Completed
                            </label>
                        </div>
                    }
                    
                    <div class="form-group">
                        <label>Notes (optional)</label>
                        <textarea @bind="_newEvent.Note" placeholder="Any additional context..." class="form-control" rows="3"></textarea>
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn-subtle" @onclick="CloseLogDialog">Cancel</button>
                    <button class="btn-gentle-primary" @onclick="SaveHealthEvent">Save</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private NyphosRiskAssessment? _assessment;
    private bool _showLogDialog = false;
    private HealthEventType _currentLogType;
    private HealthEventRequest _newEvent = new();
    private DateTime? _sleepStart;
    private DateTime? _sleepEnd;

    protected override async Task OnInitializedAsync()
    {
        await LoadAssessmentAsync();
    }

    private async Task LoadAssessmentAsync()
    {
        _loading = true;
        try
        {
            _assessment = await Http.GetFromJsonAsync<NyphosRiskAssessment>("/api/nyphos/assessment?days=7");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading Nyphos assessment: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private string GetStateSymbol(NyphosRiskState state) => state switch
    {
        NyphosRiskState.Green => "🌿",
        NyphosRiskState.Yellow => "⚡",
        NyphosRiskState.Orange => "🔥",
        NyphosRiskState.Red => "🌊",
        _ => "❓"
    };

    private string GetStateName(NyphosRiskState state) => state switch
    {
        NyphosRiskState.Green => "Steady Rhythm",
        NyphosRiskState.Yellow => "Shifting Patterns",
        NyphosRiskState.Orange => "Building Momentum",
        NyphosRiskState.Red => "Intense Energy",
        _ => "Observing"
    };

    private string GetTrendSymbol(string trend) => trend.ToLower() switch
    {
        "improving" => "↗",
        "declining" => "↘",
        "stable" => "→",
        "disrupted" => "↯",
        "insufficient" => "↓",
        "elevated" => "↑",
        "depressed" => "↓",
        "volatile" => "↔",
        _ => "·"
    };

    private string GetScoreLevel(double score) => score switch
    {
        >= 0.8 => "harmonious",
        >= 0.6 => "balanced",
        >= 0.4 => "wavering",
        _ => "strained"
    };

    private string FormatDuration(TimeSpan duration)
    {
        if (duration.TotalDays >= 1)
            return $"{(int)duration.TotalDays} day{((int)duration.TotalDays != 1 ? "s" : "")}";
        if (duration.TotalHours >= 1)
            return $"{(int)duration.TotalHours} hour{((int)duration.TotalHours != 1 ? "s" : "")}";
        return $"{(int)duration.TotalMinutes} minute{((int)duration.TotalMinutes != 1 ? "s" : "")}";
    }

    private void ShowLogDialog(HealthEventType eventType)
    {
        _currentLogType = eventType;
        _newEvent = new HealthEventRequest { EventType = eventType, RecordedAtUtc = DateTime.UtcNow };
        _sleepStart = null;
        _sleepEnd = null;
        _showLogDialog = true;
    }

    private void CloseLogDialog()
    {
        _showLogDialog = false;
    }

    private async Task SaveHealthEvent()
    {
        if (_currentLogType == HealthEventType.Sleep)
        {
            _newEvent.SleepStartUtc = _sleepStart;
            _newEvent.SleepEndUtc = _sleepEnd;
        }

        try
        {
            var response = await Http.PostAsJsonAsync("/api/health/events", _newEvent);
            if (response.IsSuccessStatusCode)
            {
                CloseLogDialog();
                await LoadAssessmentAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving health event: {ex.Message}");
        }
    }

    private async Task ActivateDownshiftProtocol()
    {
        try
        {
            var request = new { TriggeringState = _assessment!.CurrentState };
            var response = await Http.PostAsJsonAsync("/api/downshift/activate", request);
            if (response.IsSuccessStatusCode)
            {
                Navigation.NavigateTo("/nyphos/downshift");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error activating downshift protocol: {ex.Message}");
        }
    }

    private void ViewDownshiftProtocol() => Navigation.NavigateTo("/nyphos/downshift");
    private void ManageCrisisPlan() => Navigation.NavigateTo("/nyphos/crisis-plan");
    private void ViewHistory() => Navigation.NavigateTo("/wellness/history");
}
