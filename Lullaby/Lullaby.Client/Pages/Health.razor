@page "/health"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject HttpClient Http
@inject NavigationManager Navigation
@using System.Text.Json

<PageTitle>Health - Lullaby</PageTitle>

<div class="health-container">
    <div class="health-header">
        <h2>Health & Mood Tracking</h2>
        <p class="subtitle">Monitor your sleep, mood, and stability</p>
    </div>

    <div class="health-content">
        <!-- Current State Card -->
        @if (isLoading)
        {
            <div class="state-card loading">
                <div class="spinner"></div>
                <p>Loading your health state...</p>
            </div>
        }
        else if (currentState != null)
        {
            <div class="state-card">
                <div class="state-header">
                    <h3>Your Current State</h3>
                    <div class="state-badge @currentState.State.ToLower()">
                        @currentState.State
                    </div>
                </div>

                <div class="metrics-grid">
                    <div class="metric">
                        <label>Sleep Integrity</label>
                        <div class="metric-bar">
                            <div class="metric-fill" style="width: @(currentState.SleepIntegrity)%"></div>
                        </div>
                        <span class="metric-value">@currentState.SleepIntegrity%</span>
                    </div>

                    <div class="metric">
                        <label>Mood Risk</label>
                        <div class="metric-bar">
                            <div class="metric-fill risk" style="width: @(currentState.MoodRisk)%"></div>
                        </div>
                        <span class="metric-value">@currentState.MoodRisk%</span>
                    </div>

                    <div class="metric">
                        <label>Overload Index</label>
                        <div class="metric-bar">
                            <div class="metric-fill risk" style="width: @(currentState.OverloadIndex)%"></div>
                        </div>
                        <span class="metric-value">@currentState.OverloadIndex%</span>
                    </div>
                </div>

                @if (currentState.TopFactors.Length > 0)
                {
                    <div class="factors-section">
                        <h4>Top Factors</h4>
                        <div class="factors-list">
                            @foreach (var factor in currentState.TopFactors)
                            {
                                <div class="factor-badge">@factor</div>
                            }
                        </div>
                    </div>
                }

                @if (currentState.RecommendedActions.Length > 0)
                {
                    <div class="actions-section">
                        <h4>Recommended Actions</h4>
                        <div class="actions-list">
                            @foreach (var action in currentState.RecommendedActions)
                            {
                                <div class="action-item">📌 @action</div>
                            }
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Log Sleep Section -->
        <div class="log-section">
            <h3>Log Sleep</h3>
            <div class="form-group">
                <label>Sleep Start</label>
                <input type="datetime-local" @bind="sleepStart" class="form-input" />
            </div>
            <div class="form-group">
                <label>Sleep End</label>
                <input type="datetime-local" @bind="sleepEnd" class="form-input" />
            </div>
            <div class="form-group">
                <label>Quality (1-10)</label>
                <input type="number" min="1" max="10" @bind="sleepQuality" class="form-input" />
            </div>
            <button class="log-button" @onclick="LogSleep" disabled="@isLoggingSleep">
                @if (isLoggingSleep) { <span>Logging...</span> } else { <span>Log Sleep</span> }
            </button>
        </div>

        <!-- Log Mood Section -->
        <div class="log-section">
            <h3>Log Mood</h3>
            <div class="form-group">
                <label>Energy Level (-5 to +5)</label>
                <input type="number" min="-5" max="5" @bind="energyLevel" class="form-input" />
            </div>
            <div class="form-group">
                <label>Mood Score (1-10)</label>
                <input type="number" min="1" max="10" @bind="moodScore" class="form-input" />
            </div>
            <div class="form-group">
                <label>Mood Label</label>
                <select @bind="moodLabel" class="form-input">
                    <option value="">Select...</option>
                    <option value="stable">Stable</option>
                    <option value="elevated">Elevated</option>
                    <option value="irritable">Irritable</option>
                    <option value="depressed">Depressed</option>
                    <option value="anxious">Anxious</option>
                </select>
            </div>
            <div class="form-group">
                <label>Notes</label>
                <textarea @bind="moodNotes" class="form-input" placeholder="Any additional notes..."></textarea>
            </div>
            <button class="log-button" @onclick="LogMood" disabled="@isLoggingMood">
                @if (isLoggingMood) { <span>Logging...</span> } else { <span>Log Mood</span> }
            </button>
        </div>
    </div>
</div>

@code {
    private class NyphosState
    {
        public string State { get; set; } = "Green";
        public int SleepIntegrity { get; set; }
        public int MoodRisk { get; set; }
        public int OverloadIndex { get; set; }
        public string[] TopFactors { get; set; } = [];
        public string[] RecommendedActions { get; set; } = [];
        public DateTime LastUpdateUtc { get; set; }
    }

    private NyphosState? currentState;
    private bool isLoading = true;
    private bool isLoggingSleep = false;
    private bool isLoggingMood = false;

    // Sleep logging
    private DateTime sleepStart = DateTime.Now.AddHours(-8);
    private DateTime sleepEnd = DateTime.Now;
    private int? sleepQuality = 7;

    // Mood logging
    private int? energyLevel = 0;
    private int? moodScore = 5;
    private string moodLabel = "";
    private string moodNotes = "";

    private string deviceId = "default-device";

    protected override async Task OnInitializedAsync()
    {
        await RefreshState();
    }

    private async Task RefreshState()
    {
        isLoading = true;
        try
        {
            var httpRequest = new HttpRequestMessage(HttpMethod.Get, "/api/nyphos/state");
            httpRequest.Headers.Add("X-Device-Id", deviceId);

            var response = await Http.SendAsync(httpRequest);
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                currentState = JsonSerializer.Deserialize<NyphosState>(json, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading health state: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LogSleep()
    {
        if (sleepStart >= sleepEnd)
        {
            Console.WriteLine("Sleep start must be before sleep end");
            return;
        }

        isLoggingSleep = true;
        try
        {
            var request = new
            {
                sleepStart,
                sleepEnd,
                qualityScore = sleepQuality,
                interruptions = (string[]?)null
            };

            var content = new StringContent(
                JsonSerializer.Serialize(request),
                System.Text.Encoding.UTF8,
                "application/json"
            );

            var httpRequest = new HttpRequestMessage(HttpMethod.Post, "/api/nyphos/sleep")
            {
                Content = content
            };
            httpRequest.Headers.Add("X-Device-Id", deviceId);

            var response = await Http.SendAsync(httpRequest);
            if (response.IsSuccessStatusCode)
            {
                // Reset form
                sleepStart = DateTime.Now.AddHours(-8);
                sleepEnd = DateTime.Now;
                sleepQuality = 7;

                // Refresh state
                await RefreshState();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error logging sleep: {ex.Message}");
        }
        finally
        {
            isLoggingSleep = false;
        }
    }

    private async Task LogMood()
    {
        if (!moodScore.HasValue)
        {
            Console.WriteLine("Mood score is required");
            return;
        }

        isLoggingMood = true;
        try
        {
            var request = new
            {
                energyLevel,
                moodScore,
                moodLabel = string.IsNullOrWhiteSpace(moodLabel) ? null : moodLabel,
                notes = string.IsNullOrWhiteSpace(moodNotes) ? null : moodNotes
            };

            var content = new StringContent(
                JsonSerializer.Serialize(request),
                System.Text.Encoding.UTF8,
                "application/json"
            );

            var httpRequest = new HttpRequestMessage(HttpMethod.Post, "/api/nyphos/mood")
            {
                Content = content
            };
            httpRequest.Headers.Add("X-Device-Id", deviceId);

            var response = await Http.SendAsync(httpRequest);
            if (response.IsSuccessStatusCode)
            {
                // Reset form
                energyLevel = 0;
                moodScore = 5;
                moodLabel = "";
                moodNotes = "";

                // Refresh state
                await RefreshState();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error logging mood: {ex.Message}");
        }
        finally
        {
            isLoggingMood = false;
        }
    }
}
