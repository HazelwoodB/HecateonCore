@page "/wellness/history"
@using Hecateon.Client
@rendermode InteractiveWebAssembly
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Wellness History</PageTitle>

<div class="history-container">
    <div class="history-header">
        <h2>📊 Wellness History</h2>
        <div class="filter-controls">
            <select @bind="_daysFilter" @bind:after="LoadHistoryAsync">
                <option value="7">Last 7 days</option>
                <option value="14">Last 14 days</option>
                <option value="30">Last 30 days</option>
                <option value="90">Last 90 days</option>
            </select>
            <button class="btn-back" @onclick="GoBack">← Back to Dashboard</button>
        </div>
    </div>

    @if (_loading)
    {
        <div class="loading-state">
            <p>Loading your history...</p>
        </div>
    }
    else if (_events.Count == 0)
    {
        <div class="empty-state">
            <p>No wellness data recorded yet.</p>
            <button class="btn-primary" @onclick="GoBack">Start Tracking</button>
        </div>
    }
    else
    {
        <!-- Summary Stats -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon">😴</div>
                <div class="stat-value">@_events.Count(e => e.EventType == HealthEventType.Sleep)</div>
                <div class="stat-label">Sleep Logs</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">💚</div>
                <div class="stat-value">@_events.Count(e => e.EventType == HealthEventType.Mood)</div>
                <div class="stat-label">Mood Logs</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">✅</div>
                <div class="stat-value">@_events.Count(e => e.EventType == HealthEventType.Routine)</div>
                <div class="stat-label">Routine Logs</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">🏃</div>
                <div class="stat-value">@_events.Count(e => e.EventType == HealthEventType.Activity)</div>
                <div class="stat-label">Activities</div>
            </div>
        </div>

        <!-- Timeline -->
        <div class="timeline-section">
            <h3>Timeline</h3>
            <div class="timeline">
                @foreach (var group in _events.GroupBy(e => e.RecordedAtUtc.Date).OrderByDescending(g => g.Key))
                {
                    <div class="timeline-day">
                        <div class="timeline-date">
                            @group.Key.ToString("ddd, MMM d")
                        </div>
                        <div class="timeline-events">
                            @foreach (var evt in group.OrderByDescending(e => e.RecordedAtUtc))
                            {
                                <div class="event-card event-@evt.EventType.ToString().ToLowerInvariant()">
                                    <div class="event-header">
                                        <span class="event-icon">@GetEventIcon(evt.EventType)</span>
                                        <span class="event-type">@evt.EventType</span>
                                        <span class="event-time">@evt.RecordedAtUtc.ToLocalTime().ToString("h:mm tt")</span>
                                    </div>
                                    <div class="event-details">
                                        @if (evt.EventType == HealthEventType.Sleep)
                                        {
                                            <div>
                                                <strong>Duration:</strong> @(Math.Round((evt.SleepEndUtc!.Value - evt.SleepStartUtc!.Value).TotalHours, 1)) hours
                                                <br />
                                                <strong>Quality:</strong> @evt.SleepQuality/5
                                            </div>
                                        }
                                        else if (evt.EventType == HealthEventType.Mood)
                                        {
                                            <div>
                                                <strong>Mood:</strong> @GetMoodLabel(evt.MoodScore!.Value)
                                                @if (!string.IsNullOrWhiteSpace(evt.MoodLabel))
                                                {
                                                    <br />
                                                    <strong>Feeling:</strong> @evt.MoodLabel
                                                }
                                            </div>
                                        }
                                        else if (evt.EventType == HealthEventType.Routine)
                                        {
                                            <div>
                                                <strong>Routine:</strong> @evt.RoutineName
                                                <br />
                                                <strong>Status:</strong> @(evt.RoutineCompleted == true ? "✓ Completed" : "✗ Incomplete")
                                            </div>
                                        }
                                        else if (evt.EventType == HealthEventType.Activity)
                                        {
                                            <div>
                                                <strong>Activity:</strong> @evt.ActivityType
                                                <br />
                                                <strong>Duration:</strong> @evt.DurationMinutes minutes
                                            </div>
                                        }
                                        else if (evt.EventType == HealthEventType.Medication)
                                        {
                                            <div>
                                                <strong>Medication:</strong> @evt.MedicationName
                                                <br />
                                                <strong>Taken:</strong> @(evt.MedicationTaken == true ? "Yes ✓" : "No ✗")
                                            </div>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(evt.Note))
                                        {
                                            <div class="event-note">
                                                <em>Note: @evt.Note</em>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private int _daysFilter = 30;
    private List<HealthEvent> _events = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadHistoryAsync();
    }

    private async Task LoadHistoryAsync()
    {
        _loading = true;
        try
        {
            _events = await Http.GetFromJsonAsync<List<HealthEvent>>($"/api/health/history?days={_daysFilter}") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading history: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private void GoBack() => Navigation.NavigateTo("/wellness");

    private string GetEventIcon(HealthEventType type) => type switch
    {
        HealthEventType.Sleep => "😴",
        HealthEventType.Mood => "💚",
        HealthEventType.Routine => "✅",
        HealthEventType.Medication => "💊",
        HealthEventType.Activity => "🏃",
        HealthEventType.Note => "📝",
        _ => "📋"
    };

    private string GetMoodLabel(int score) => score switch
    {
        -2 => "😢 Very Low",
        -1 => "😟 Low",
        0 => "😐 Neutral",
        1 => "😊 Good",
        2 => "😄 Great",
        _ => "❓ Unknown"
    };
}
