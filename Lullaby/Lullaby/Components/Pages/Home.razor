@page "/"

<PageTitle>Home - Lullaby</PageTitle>

<div class="home-container">
    <div class="hero-section">
        <h1>🌙 Lullaby</h1>
        <p class="tagline">Your personal mental health companion</p>
    </div>

    <div class="welcome-card">
        <h2>Welcome Back</h2>
        <p>Lullaby is a private, offline-capable platform for tracking your mental health, sleep patterns, and mood. Everything stays on your device.</p>
        
        <div class="quick-links">
            <a href="chat" class="link-button primary">
                <span class="icon">💬</span> Start Chatting
            </a>
            <a href="health" class="link-button secondary">
                <span class="icon">❤️</span> View Health Data
            </a>
            <a href="settings" class="link-button secondary">
                <span class="icon">⚙️</span> Settings
            </a>
        </div>
    </div>

    <div class="features">
        <div class="feature-card">
            <h3>Private & Secure</h3>
            <p>Your data is encrypted and stays on your device. No cloud required.</p>
        </div>
        <div class="feature-card">
            <h3>Offline Ready</h3>
            <p>Works offline. Syncs when you're ready.</p>
        </div>
        <div class="feature-card">
            <h3>Always You Control</h3>
            <p>You choose what to share and when. Explicit consent always.</p>
        </div>
    </div>
</div>

