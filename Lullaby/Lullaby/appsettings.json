{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ChatDb": "Server=(localdb)\\mssqllocaldb;Database=AutoPC_ChatDb;Trusted_Connection=true;",
    "ChatDbSqlite": "Data Source=App_Data/hecateon-chat.db"
  },
  "Hecateon": {
    "DatabaseProvider": "sqlite",
    "EventStore": {
      "MaxPayloadBytes": 262144,
      "MaxPullLimit": 1000
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
