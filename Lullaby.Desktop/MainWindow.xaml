<Window x:Class="Lullaby.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Lullaby - Mental Health Companion" 
        Height="820" 
        Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#FAFBFC"
        Foreground="#1A1A1A"
        FontFamily="Segoe UI"
        FontSize="14"
        MinHeight="700"
        MinWidth="900">
    
    <Window.Resources>
        <Color x:Key="Primary">#6366F1</Color>
        <Color x:Key="PrimaryLight">#A5B4FC</Color>
        <Color x:Key="PrimaryDark">#4F46E5</Color>
        <Color x:Key="Success">#10B981</Color>
        <Color x:Key="Warning">#F59E0B</Color>
        <Color x:Key="Error">#EF4444</Color>
        <Color x:Key="Surface">#FFFFFF</Color>
        <Color x:Key="SurfaceAlt">#F3F4F6</Color>
        <Color x:Key="BorderColor">#E5E7EB</Color>
        <Color x:Key="TextDark">#111827</Color>
        <Color x:Key="TextMed">#6B7280</Color>
        <Color x:Key="TextLight">#9CA3AF</Color>
        
        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
        <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLight}"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDark}"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="TextDarkBrush" Color="{StaticResource TextDark}"/>
        <SolidColorBrush x:Key="TextMedBrush" Color="{StaticResource TextMed}"/>
        <SolidColorBrush x:Key="TextLightBrush" Color="{StaticResource TextLight}"/>

        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMedBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="Transparent" BorderThickness="0,0,0,3" BorderBrush="Transparent" Padding="18,14" Name="Border">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F9FAFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="13"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{StaticResource PrimaryBrush}" Padding="32,20">
            <Grid>
                <StackPanel>
                    <TextBlock Text="?? Lullaby" FontSize="32" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Your Personal Mental Health Companion" FontSize="13" Foreground="#E0E7FF" Margin="0,5,0,0" Opacity="0.95"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse x:Name="ConnectionDot" Width="12" Height="12" Fill="{StaticResource SuccessBrush}" Margin="0,0,14,0"/>
                    <TextBlock x:Name="ConnectionStatus" Text="Connected" Foreground="White" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tabs -->
        <Border DockPanel.Dock="Top" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <TabControl Background="White" TabStripPlacement="Top" Margin="0" Padding="0">
                <TabItem Header="?? Messages" Style="{StaticResource TabItemStyle}">
                    <Grid Background="#F8F9FA">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListBox x:Name="MessagesList" Grid.Row="0" Background="#F8F9FA" BorderThickness="0" ItemsSource="{Binding ChatMessages}" ScrollViewer.VerticalScrollBarVisibility="Auto" Padding="24">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,10,0,10">
                                        <StackPanel HorizontalAlignment="Right" Visibility="{Binding IsUserVisibility}" Margin="100,0,0,0" MaxWidth="550">
                                            <Border Background="{StaticResource PrimaryBrush}" Padding="16,12" CornerRadius="18,18,6,18">
                                                <TextBlock Text="{Binding Text}" Foreground="White" TextWrapping="Wrap" FontSize="13" LineHeight="20"/>
                                            </Border>
                                            <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm'}" Foreground="{StaticResource TextLightBrush}" FontSize="11" Margin="0,8,0,0" TextAlignment="Right"/>
                                        </StackPanel>

                                        <StackPanel HorizontalAlignment="Left" Visibility="{Binding IsAssistantVisibility}" Margin="0,0,100,0" MaxWidth="550">
                                            <Border Background="White" Padding="16,12" CornerRadius="18,18,18,6" BorderBrush="#E5E7EB" BorderThickness="1">
                                                <TextBlock Text="{Binding Text}" Foreground="{StaticResource TextDarkBrush}" TextWrapping="Wrap" FontSize="13" LineHeight="20"/>
                                            </Border>
                                            <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm'}" Foreground="{StaticResource TextLightBrush}" FontSize="11" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Error -->
                        <Border Grid.Row="0" Background="#FECACA" BorderBrush="#FCA5A5" BorderThickness="0,0,0,1" Padding="18" Visibility="Collapsed" x:Name="ErrorBanner" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="?? Error" Foreground="#7F1D1D" FontWeight="Bold" FontSize="13"/>
                                <TextBlock x:Name="ErrorMessage" Foreground="#991B1B" TextWrapping="Wrap" FontSize="12" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Input -->
                        <Border Grid.Row="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="24">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ChatInput" Grid.Column="0" Style="{StaticResource TextBoxStyle}" MinHeight="50" MaxHeight="130" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,14,0"/>
                                <Button Grid.Column="1" Content="Send" Click="SendMessage_Click" Style="{StaticResource ButtonStyle}" MinHeight="50" VerticalAlignment="Bottom"/>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="?? Health" Style="{StaticResource TabItemStyle}">
                    <ScrollViewer Background="White" Padding="32">
                        <StackPanel MaxWidth="680">
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Daily Check-In" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}"/>
                                <TextBlock Text="Track your wellbeing to discover patterns" Foreground="{StaticResource TextMedBrush}" FontSize="14" Margin="0,5,0,0"/>
                            </StackPanel>

                            <Border Background="White" Padding="28" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1.5" Margin="0,20,0,20">
                                <StackPanel>
                                    <TextBlock Text="What's your mood today?" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" FontSize="16" Margin="0,0,0,18"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,18">
                                        <Button Content="??&#10;Great" Tag="5" Click="MoodButton_Click" Style="{StaticResource ButtonStyle}" Width="100" Height="100" Padding="8" FontSize="14" Margin="0,0,12,0"/>
                                        <Button Content="??&#10;Good" Tag="4" Click="MoodButton_Click" Style="{StaticResource ButtonStyle}" Width="100" Height="100" Padding="8" FontSize="14" Margin="0,0,12,0"/>
                                        <Button Content="??&#10;Okay" Tag="3" Click="MoodButton_Click" Style="{StaticResource ButtonStyle}" Width="100" Height="100" Padding="8" FontSize="14" Margin="0,0,12,0"/>
                                        <Button Content="??&#10;Bad" Tag="2" Click="MoodButton_Click" Style="{StaticResource ButtonStyle}" Width="100" Height="100" Padding="8" FontSize="14" Margin="0,0,12,0"/>
                                        <Button Content="??&#10;Awful" Tag="1" Click="MoodButton_Click" Style="{StaticResource ButtonStyle}" Width="100" Height="100" Padding="8" FontSize="14"/>
                                    </StackPanel>
                                    <TextBlock x:Name="MoodLabel" Text="Select your mood to continue" Foreground="{StaticResource TextMedBrush}" FontSize="13" TextAlignment="Center" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="White" Padding="28" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1.5" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="How much sleep did you get?" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" FontSize="16" Margin="0,0,0,18"/>
                                    <Slider x:Name="SleepSlider" Minimum="0" Maximum="12" SmallChange="0.25" LargeChange="1" Value="8" Height="6" Margin="0,0,0,14"/>
                                    <TextBlock x:Name="SleepLabel" Text="8.0 hours" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold" FontSize="18" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Button Content="? Save Entry" Click="LogHealth_Click" Style="{StaticResource ButtonStyle}" Padding="16,16" FontSize="15" MinHeight="54" Width="200" Margin="0,0,0,20"/>

                            <Border Background="#DCFCE7" Padding="22" CornerRadius="14" BorderBrush="#A7F3D0" BorderThickness="1.5">
                                <StackPanel>
                                    <TextBlock Text="Last Check-In" FontWeight="Bold" Foreground="#166534" FontSize="12" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="HealthStatus" Text="No entries yet" Foreground="#15803D" FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="?? Settings" Style="{StaticResource TabItemStyle}">
                    <ScrollViewer Background="White" Padding="32">
                        <StackPanel MaxWidth="680">
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Settings" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}"/>
                                <TextBlock Text="Manage your account and privacy" Foreground="{StaticResource TextMedBrush}" FontSize="14" Margin="0,5,0,0"/>
                            </StackPanel>

                            <Border Background="White" Padding="28" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1.5" Margin="0,20,0,20">
                                <StackPanel>
                                    <TextBlock Text="Device ID" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" FontSize="15" Margin="0,0,0,16"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="DeviceIdBox" Grid.Column="0" Style="{StaticResource TextBoxStyle}" IsReadOnly="True" FontFamily="Courier New" FontSize="11" Padding="13" Height="46"/>
                                        <Button Grid.Column="1" Content="Copy" Click="CopyDeviceId_Click" Style="{StaticResource ButtonStyle}" Padding="14,10" Margin="14,0,0,0" Height="46" VerticalAlignment="Top"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="#FEF08A" Padding="28" CornerRadius="14" BorderBrush="#FCD34D" BorderThickness="1.5" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="Recovery Code" FontWeight="Bold" Foreground="#78350F" FontSize="15" Margin="0,0,0,8"/>
                                    <TextBlock Text="Store this safely. It grants full account access." FontSize="13" Foreground="#92400E" TextWrapping="Wrap" Margin="0,0,0,16"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="RecoveryCodeBox" Grid.Column="0" Style="{StaticResource TextBoxStyle}" IsReadOnly="True" FontFamily="Courier New" FontSize="11" Padding="13" Height="46"/>
                                        <Button x:Name="ShowRecoveryBtn" Grid.Column="1" Content="Show" Click="ToggleRecoveryCode_Click" Style="{StaticResource ButtonStyle}" Padding="14,10" Margin="14,0,0,0" Height="46" VerticalAlignment="Top"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="White" Padding="28" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1.5" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="Security" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" FontSize="15" Margin="0,0,0,16"/>
                                    <StackPanel Margin="0,0,0,12">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <TextBlock Text="??" FontSize="16" Margin="0,0,10,0"/>
                                            <TextBlock Text="AES-256-GCM military-grade encryption" Foreground="{StaticResource TextMedBrush}" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <TextBlock Text="??" FontSize="16" Margin="0,0,10,0"/>
                                            <TextBlock Text="Immutable event-sourced history" Foreground="{StaticResource TextMedBrush}" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <TextBlock Text="??" FontSize="16" Margin="0,0,10,0"/>
                                            <TextBlock Text="Works offline, no cloud sync" Foreground="{StaticResource TextMedBrush}" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="??" FontSize="16" Margin="0,0,10,0"/>
                                            <TextBlock Text="Your device is the source of truth" Foreground="{StaticResource TextMedBrush}" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="White" Padding="28" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1.5">
                                <StackPanel>
                                    <TextBlock Text="About" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" FontSize="15" Margin="0,0,0,12"/>
                                    <TextBlock Text="Lullaby v1.0" Foreground="{StaticResource TextMedBrush}" FontSize="13" Margin="0,0,0,4"/>
                                    <TextBlock Text="A privacy-first mental health companion designed for your wellbeing" Foreground="{StaticResource TextMedBrush}" FontSize="13" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>
    </DockPanel>
</Window>
